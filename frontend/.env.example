# Weather API Configuration
# Get your free API key from: https://openweathermap.org/api

# OpenWeatherMap API Key (for Vite, use VITE_ prefix)
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Optional: Set your default location (if geolocation fails)
VITE_DEFAULT_CITY=New York
VITE_DEFAULT_COUNTRY=US

# Weather data refresh interval (in minutes)
VITE_WEATHER_REFRESH_INTERVAL=30

# Weather cache timeout (in minutes) 
VITE_WEATHER_CACHE_TIMEOUT=10