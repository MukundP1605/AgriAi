/* Product placeholder SVG in Base64 */
const base64Image = `data:image/svg+xml;base64,`;

/* Create an actual file from the Base64 */
const img = new Image();
img.src = base64Image;

/* Save the image */
fetch(img.src)
  .then(res => res.blob())
  .then(blob => {
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = 'default.jpg';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  });
